---
import { getImage } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import MunroCard from '../../components/MunroCard.astro';
import WikimediaImage from '../../components/WikimediaImage.astro';
import StaticMap from '../../components/StaticMap.astro';
import AppCTA from '../../components/AppCTA.astro';
import { munros } from '../../data/munros';
import { heroImage } from '../../data/heroes';
import { nearbyMunros } from '../../data/derived';
import { munroBranchLink } from '../../lib/branch';
import { munroTitle, munroDescription, mountainJsonLd, mobileAppJsonLd } from '../../lib/seo';

export function getStaticPaths() {
  return munros.map((munro) => ({ params: { slug: munro.slug }, props: { munro } }));
}

const { munro } = Astro.props;
const nearby = nearbyMunros(munro);
const branchLink = munroBranchLink(munro);

const ogImage = await getImage({
  src: heroImage(munro.slug) ?? munro.heroImageUrl,
  width: 1200,
  height: 630,
  fit: 'cover',
  format: 'jpeg',
});

const path = `/munros/${munro.slug}`;
const crumbs = [
  { name: 'Home', path: '/' },
  { name: 'Munros', path: '/munros' },
  { name: munro.area, path: `/regions/${munro.areaSlug}` },
  { name: munro.displayName },
];
---

<Base
  title={munroTitle(munro)}
  description={munroDescription(munro)}
  path={path}
  ogImage={ogImage.src}
  jsonLd={[mountainJsonLd(munro, ogImage.src), mobileAppJsonLd()]}
  appArgument={branchLink}
>
  <article class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <Breadcrumbs crumbs={crumbs} />

    <div class="mt-4 overflow-hidden rounded-3xl">
      <WikimediaImage munro={munro} class="aspect-[3/2] w-full" />
    </div>

    <header class="mt-6">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
        {munro.name}
        {munro.qualifier && <span class="text-gray-500">({munro.qualifier})</span>}
      </h1>
      <dl class="mt-4 grid grid-cols-2 gap-4 sm:grid-cols-4">
        <div class="rounded-2xl border border-gray-200 bg-white p-3 text-center">
          <dt class="text-xs font-medium text-gray-500 uppercase">Height</dt>
          <dd class="mt-1 font-bold text-gray-900">
            {munro.meters}m <span class="text-sm font-normal text-gray-500">({munro.feet.toLocaleString()}ft)</span>
          </dd>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-3 text-center">
          <dt class="text-xs font-medium text-gray-500 uppercase">Height rank</dt>
          <dd class="mt-1 font-bold text-gray-900">{munro.heightRank} of 282</dd>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-3 text-center">
          <dt class="text-xs font-medium text-gray-500 uppercase">Area</dt>
          <dd class="mt-1 font-bold text-gray-900">
            <a href={`/regions/${munro.areaSlug}`} class="hover:text-brand-600">{munro.area}</a>
          </dd>
        </div>
        <div class="rounded-2xl border border-gray-200 bg-white p-3 text-center">
          <dt class="text-xs font-medium text-gray-500 uppercase">Section</dt>
          <dd class="mt-1 text-sm font-bold text-gray-900">{munro.region.replace(/^\S+\s/, '')}</dd>
        </div>
      </dl>
    </header>

    <section class="prose prose-gray mt-8 max-w-none">
      <h2>About {munro.name}</h2>
      <p>{munro.description}</p>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-bold">Where is {munro.name}?</h2>
      <p class="mt-2 text-gray-600">
        {munro.displayName} sits in the {munro.region.replace(/^\S+\s/, '')} region of {munro.area}
        at {munro.lat.toFixed(4)}°N, {Math.abs(munro.lng).toFixed(4)}°W.
      </p>
      <div class="mt-4">
        <StaticMap munro={munro} />
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-bold">Key facts</h2>
      <div class="mt-4 overflow-x-auto">
        <table class="w-full text-left text-sm">
          <tbody class="divide-y divide-gray-200">
            <tr>
              <th scope="row" class="py-2 pr-4 font-medium text-gray-500">Height</th>
              <td class="py-2">{munro.meters} metres / {munro.feet.toLocaleString()} feet</td>
            </tr>
            <tr>
              <th scope="row" class="py-2 pr-4 font-medium text-gray-500">Rank by height</th>
              <td class="py-2">{munro.heightRank} of 282 Munros</td>
            </tr>
            <tr>
              <th scope="row" class="py-2 pr-4 font-medium text-gray-500">Coordinates</th>
              <td class="py-2">{munro.lat.toFixed(5)}, {munro.lng.toFixed(5)}</td>
            </tr>
            {
              munro.extra && (
                <tr>
                  <th scope="row" class="py-2 pr-4 font-medium text-gray-500">Group</th>
                  <td class="py-2">{munro.extra}</td>
                </tr>
              )
            }
            <tr>
              <th scope="row" class="py-2 pr-4 font-medium text-gray-500">Area</th>
              <td class="py-2">{munro.area}</td>
            </tr>
            <tr>
              <th scope="row" class="py-2 pr-4 font-medium text-gray-500">SMC section</th>
              <td class="py-2">{munro.region}</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-8">
      <h2 class="text-xl font-bold">Plan your climb</h2>
      <div class="mt-4 flex flex-wrap gap-3">
        <a
          href={munro.link}
          rel="noopener"
          class="rounded-full border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-800 transition hover:border-brand-500 hover:text-brand-600"
          >Route details on WalkHighlands ↗</a
        >
        <a
          href={munro.startingPointUrl}
          rel="noopener"
          class="rounded-full border border-gray-300 bg-white px-5 py-2.5 text-sm font-semibold text-gray-800 transition hover:border-brand-500 hover:text-brand-600"
          >Starting point on Google Maps ↗</a
        >
      </div>
      <p class="mt-3 text-sm text-gray-500">
        Check the forecast and daylight before you go — the 282 app shows a 7-day summit forecast
        for {munro.name}.
      </p>
    </section>

    {
      nearby.length > 0 && (
        <section class="mt-10">
          <h2 class="text-xl font-bold">Commonly climbed with</h2>
          <p class="mt-2 text-gray-600">
            Munros close to {munro.displayName} that baggers often combine in a single day or trip.
          </p>
          <div class="mt-4 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {nearby.map((m) => (
              <MunroCard munro={m} />
            ))}
          </div>
        </section>
      )
    }

    <div class="mt-10">
      <AppCTA heading={`Track ${munro.name} in the 282 app`} branchLink={branchLink} />
    </div>
  </article>
</Base>
