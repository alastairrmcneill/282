---
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AppCTA from '../../components/AppCTA.astro';
import { areas, munros } from '../../data/munros';
import { appBranchLink } from '../../lib/branch';
import { mobileAppJsonLd } from '../../lib/seo';
---

<Base
  title="All 282 Munros — The Complete List by Region | 282"
  description="The full list of all 282 Scottish Munros, organised by region with heights. Every mountain over 3,000ft in Scotland — find your next climb and track it with the 282 app."
  path="/munros"
  jsonLd={[mobileAppJsonLd()]}
>
  <div class="mx-auto max-w-6xl px-4 py-8 sm:px-6">
    <Breadcrumbs crumbs={[{ name: 'Home', path: '/' }, { name: 'Munros' }]} />

    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">All 282 Munros</h1>
    <p class="mt-3 max-w-3xl text-gray-600">
      A Munro is a Scottish mountain over 3,000 feet (914.4m). There are currently
      <strong>282 Munros</strong>, from Ben Nevis at 1,345m to Beinn Teallach at 915m. Browse the
      complete list by region below — every peak links to its own page with a map, photos and route
      info. <a href="/guides/what-is-a-munro" class="text-brand-600 underline">New to Munro bagging?</a>
    </p>

    <nav aria-label="Regions" class="mt-6 flex flex-wrap gap-2">
      {
        areas.map((area) => (
          <a
            href={`#${area.slug}`}
            class="rounded-full border border-gray-300 bg-white px-4 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-500 hover:text-brand-600"
          >
            {area.name} ({area.munros.length})
          </a>
        ))
      }
    </nav>

    {
      areas.map((area) => (
        <section id={area.slug} class="mt-10 scroll-mt-20">
          <div class="flex items-baseline justify-between">
            <h2 class="text-2xl font-bold">{area.name}</h2>
            <a href={`/regions/${area.slug}`} class="text-sm font-medium text-brand-600 hover:underline">
              Munros in {area.name} →
            </a>
          </div>
          <div class="mt-3 overflow-hidden rounded-2xl border border-gray-200 bg-white">
            <table class="w-full text-left text-sm">
              <thead class="bg-gray-50 text-xs text-gray-500 uppercase">
                <tr>
                  <th scope="col" class="px-4 py-2">Munro</th>
                  <th scope="col" class="px-4 py-2 text-right">Height</th>
                  <th scope="col" class="hidden px-4 py-2 text-right sm:table-cell">Rank</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                {area.munros.map((m) => (
                  <tr class="hover:bg-gray-50">
                    <td class="px-4 py-2">
                      <a href={`/munros/${m.slug}`} class="font-medium text-gray-900 hover:text-brand-600">
                        {m.displayName}
                      </a>
                    </td>
                    <td class="px-4 py-2 text-right whitespace-nowrap">{m.meters}m</td>
                    <td class="hidden px-4 py-2 text-right sm:table-cell">{m.heightRank}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      ))
    }

    <p class="mt-8 text-sm text-gray-500">{munros.length} Munros listed.</p>

    <div class="mt-10">
      <AppCTA
        heading="Tick them off as you go"
        branchLink={appBranchLink('munro_index')}
      />
    </div>
  </div>
</Base>
