---
import Base from '../layouts/Base.astro';
import AppCTA from '../components/AppCTA.astro';
import { appBranchLink } from '../lib/branch';
---

<Base
  title="Page not found | 282"
  description="That page has wandered off the path. Find all 282 Munros, guides and the 282 app here."
  path="/404"
>
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:px-6">
    <p class="text-6xl font-extrabold text-brand-500">404</p>
    <h1 class="mt-4 text-3xl font-bold">This path doesn't lead to a summit</h1>
    <p class="mt-3 text-gray-600">
      The page you're looking for doesn't exist. Try the full list of Munros or head back to base.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <a
        href="/munros"
        class="rounded-full bg-brand-500 px-6 py-2.5 font-semibold text-white hover:bg-brand-600"
        >All 282 Munros</a
      >
      <a
        href="/"
        class="rounded-full border border-gray-300 px-6 py-2.5 font-semibold text-gray-700 hover:bg-gray-100"
        >Home</a
      >
    </div>
    <div class="mt-14">
      <AppCTA branchLink={appBranchLink('404')} />
    </div>
  </div>
</Base>
