---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import MunroCard from '../components/MunroCard.astro';
import AppCTA from '../components/AppCTA.astro';
import { munros, munrosBySlug, areas } from '../data/munros';
import landingHero from '../assets/landing-hero.webp';
import { appBranchLink, APP_STORE_URL, PLAY_STORE_URL } from '../lib/branch';
import { mobileAppJsonLd } from '../lib/seo';

const popular = ['ben-nevis', 'schiehallion', 'ben-lomond', 'ben-macdui', 'cairn-gorm', 'stob-dearg-buachaille-etive-mor']
  .map((slug) => munrosBySlug.get(slug))
  .filter((m) => m !== undefined);

const features = [
  {
    title: 'Every Munro on the map',
    text: 'An interactive map of all 282 Munros. See what you have climbed, what is nearby and where to go next.',
  },
  {
    title: 'Log your summits',
    text: 'Tick off Munros with dates and notes, and watch your progress towards the full round of 282.',
  },
  {
    title: 'Share your adventures',
    text: 'Post summit photos, follow friends and get inspired by fellow baggers in the community feed.',
  },
  {
    title: 'Earn achievements',
    text: 'Badges for regions completed, multi-Munro days, annual challenges and more — with confetti.',
  },
  {
    title: 'Summit weather forecasts',
    text: 'A 7-day forecast for every Munro so you can pick the right day for the right hill.',
  },
  {
    title: 'Reviews from real baggers',
    text: 'Star ratings and honest write-ups on every Munro from people who have climbed it.',
  },
];

const guideLinks = [
  { href: '/guides/what-is-a-munro', label: 'What is a Munro?' },
  { href: '/guides/munro-bagging-for-beginners', label: 'Munro bagging for beginners' },
  { href: '/guides/easiest-munros', label: 'The easiest Munros' },
  { href: '/guides/munro-map', label: 'Munro map by region' },
];
---

<Base
  title="282: Munro Bagging App — Track All 282 Scottish Munros"
  description="282 is the free Munro bagging app for iOS and Android. Track your Munro progress on an interactive map, log summits, check summit weather, earn badges and share photos with fellow baggers."
  path="/"
  jsonLd={[mobileAppJsonLd()]}
>
  <!-- Hero -->
  <section class="relative isolate overflow-hidden bg-gray-900">
    <Image
      src={landingHero}
      alt="A hillwalker looking out over An Stuc and Lochan nan Cat from Ben Lawers in winter"
      width={1920}
      height={1080}
      widths={[768, 1280, 1920]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="absolute inset-0 -z-10 h-full w-full object-cover opacity-50"
    />
    <div class="mx-auto max-w-6xl px-4 py-24 sm:px-6 sm:py-32">
      <div class="max-w-2xl">
        <h1 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl">
          The Munro bagging app for all <span class="text-brand-400">282</span> Scottish peaks
        </h1>
        <p class="mt-5 text-lg text-gray-200">
          Track every Munro you climb, plan the next one on the map, check summit weather and
          share the journey with a community of fellow baggers. Free on iOS and Android.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={APP_STORE_URL} aria-label="Download 282 on the App Store">
            <img src="/badges/app-store.svg" alt="Download on the App Store" width="150" height="50" />
          </a>
          <a href={PLAY_STORE_URL} aria-label="Get 282 on Google Play">
            <img src="/badges/google-play.svg" alt="Get it on Google Play" width="168" height="50" />
          </a>
        </div>
      </div>
    </div>
    <p class="absolute right-2 bottom-1 text-[11px] text-gray-300">
      An Stuc from Ben Lawers — photo: Alastair McNeill
    </p>
  </section>

  <!-- Stats -->
  <section class="border-b border-gray-200 bg-white">
    <dl class="mx-auto grid max-w-6xl grid-cols-3 gap-4 px-4 py-8 text-center sm:px-6">
      <div>
        <dt class="text-sm text-gray-500">Munros to bag</dt>
        <dd class="text-3xl font-extrabold text-brand-600">282</dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Regions to explore</dt>
        <dd class="text-3xl font-extrabold text-brand-600">{areas.length}</dd>
      </div>
      <div>
        <dt class="text-sm text-gray-500">Highest summit</dt>
        <dd class="text-3xl font-extrabold text-brand-600">1,345m</dd>
      </div>
    </dl>
  </section>

  <!-- Features -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-center text-3xl font-bold tracking-tight">
      Everything a Munro bagger needs
    </h2>
    <p class="mx-auto mt-3 max-w-2xl text-center text-gray-600">
      From your first Munro to your last, 282 keeps your whole journey in one place.
    </p>
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((f) => (
          <div class="rounded-2xl border border-gray-200 bg-white p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900">{f.title}</h3>
            <p class="mt-2 text-sm text-gray-600">{f.text}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- Screenshots -->
  <section class="bg-gray-900 py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-center text-3xl font-bold text-white">See it in action</h2>
      <div class="mt-10 flex flex-wrap items-start justify-center gap-8">
        {
          [
            { label: 'Explore the map', file: 'explore-map.PNG' },
            { label: 'Read reviews', file: 'read-reviews.PNG' },
            { label: 'Share the moment', file: 'share-moment.PNG' },
          ].map(({ label, file }) => (
            <figure class="w-56">
              <div class="aspect-[9/19.5] overflow-hidden rounded-[2rem] border-4 border-gray-700 bg-gray-800">
                <img
                  src={`/screenshots/${file}`}
                  alt={label}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              </div>
              <figcaption class="mt-3 text-center text-sm text-gray-300">{label}</figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Popular munros -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <div class="flex items-baseline justify-between">
      <h2 class="text-3xl font-bold tracking-tight">Popular Munros</h2>
      <a href="/munros" class="text-sm font-medium text-brand-600 hover:underline">
        All 282 Munros →
      </a>
    </div>
    <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {popular.map((m) => <MunroCard munro={m} />)}
    </div>
  </section>

  <!-- Regions -->
  <section class="bg-white py-16">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <h2 class="text-3xl font-bold tracking-tight">Explore by region</h2>
      <p class="mt-2 max-w-2xl text-gray-600">
        From the Cairngorms to the Cuillin of Skye — {munros.length} Munros across
        {areas.length} areas of the Scottish Highlands and islands.
      </p>
      <div class="mt-6 flex flex-wrap gap-3">
        {
          areas.map((a) => (
            <a
              href={`/regions/${a.slug}`}
              class="rounded-full border border-gray-300 px-4 py-2 text-sm font-medium text-gray-700 transition hover:border-brand-500 hover:text-brand-600"
            >
              {a.name} <span class="text-gray-400">({a.munros.length})</span>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <!-- Guides teaser -->
  <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
    <h2 class="text-3xl font-bold tracking-tight">New to Munro bagging?</h2>
    <p class="mt-2 max-w-2xl text-gray-600">
      Start with our guides — what a Munro actually is, which ones to climb first and how to plan
      a full round.
    </p>
    <ul class="mt-6 grid gap-3 sm:grid-cols-2">
      {
        guideLinks.map((g) => (
          <li>
            <a
              href={g.href}
              class="block rounded-2xl border border-gray-200 bg-white p-4 font-medium text-gray-800 transition hover:border-brand-500 hover:text-brand-600"
            >
              {g.label} →
            </a>
          </li>
        ))
      }
    </ul>
  </section>

  <div class="mx-auto max-w-6xl px-4 pb-16 sm:px-6">
    <AppCTA heading="Start your round of 282 today" branchLink={appBranchLink('landing')} />
  </div>
</Base>
