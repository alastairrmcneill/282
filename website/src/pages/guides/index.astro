---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import AppCTA from '../../components/AppCTA.astro';
import { appBranchLink } from '../../lib/branch';

const guides = (await getCollection('guides')).sort(
  (a, b) => a.data.publishDate.valueOf() - b.data.publishDate.valueOf(),
);
---

<Base
  title="Munro Bagging Guides — Beginner Tips, Maps & Lists | 282"
  description="Guides to Munro bagging in Scotland: what a Munro is, the easiest and hardest peaks, maps by region, and how to plan a full round of all 282."
  path="/guides"
>
  <div class="mx-auto max-w-4xl px-4 py-8 sm:px-6">
    <Breadcrumbs crumbs={[{ name: 'Home', path: '/' }, { name: 'Guides' }]} />
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">Munro bagging guides</h1>
    <p class="mt-3 max-w-2xl text-gray-600">
      Everything you need to get into the hills — from your very first Munro to completing the
      round of 282.
    </p>
    <div class="mt-8 space-y-4">
      {
        guides.map((g) => (
          <a
            href={`/guides/${g.id}`}
            class="block rounded-2xl border border-gray-200 bg-white p-6 transition hover:border-brand-500 hover:shadow-md"
          >
            <h2 class="text-xl font-semibold text-gray-900">{g.data.title}</h2>
            <p class="mt-2 text-sm text-gray-600">{g.data.description}</p>
          </a>
        ))
      }
    </div>
    <div class="mt-10">
      <AppCTA branchLink={appBranchLink('guides_index')} />
    </div>
  </div>
</Base>
