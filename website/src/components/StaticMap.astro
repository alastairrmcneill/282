---
import fs from 'node:fs';
import path from 'node:path';
import type { Munro } from '../data/munros';

interface Props {
  munro: Munro;
}

const { munro } = Astro.props;

// Maps are pre-generated by scripts/generate-maps.mjs and committed to public/.
const mapPath = `/static/maps/${munro.slug}.webp`;
const exists = fs.existsSync(path.join(process.cwd(), 'public', mapPath));
---

{
  exists && (
    <img
      src={mapPath}
      alt={`Map showing the location of ${munro.displayName} in ${munro.area}, Scotland`}
      width="1280"
      height="800"
      loading="lazy"
      class="w-full rounded-2xl border border-gray-200"
    />
  )
}
